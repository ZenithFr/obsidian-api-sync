# Obsidian API Sync -- Environment Configuration

# A long random string for signing session cookies.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Admin password for the /dashboard login screen.
ADMIN_PASSWORD=change-me

# Server bind settings.
HOST=0.0.0.0
PORT=8000

# SQLite database file path.
DB_PATH=./obsidian-sync.db

# Fallback vault path used only if DB has no vault_path set yet.
DEFAULT_VAULT_PATH=./vault

# ---- Security Settings ----
CORS_ORIGINS=
HTTPS_ONLY=false
RATE_LIMIT_ENABLED=true
MAX_FILE_SIZE_BYTES=10485760

# ---- Google Drive OAuth2 (optional) ----------------------------------------
# Only needed if you want to use Google Drive as the storage backend.
#
# Setup (one-time, ~5 minutes):
#   1. Go to https://console.cloud.google.com
#   2. Create a project -> Enable "Google Drive API"
#   3. Go to APIs & Services -> Credentials -> Create OAuth 2.0 Client ID
#   4. Application type: Web Application
#   5. Add Authorized Redirect URI: http://YOUR_SERVER/auth/google/callback
#   6. Copy Client ID and Client Secret below
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match the Redirect URI you added in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
