# Obsidian API Sync -- Environment Configuration

# A long random string for signing session cookies.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Admin password for the /dashboard login screen.
ADMIN_PASSWORD=change-me

# Server bind settings.
HOST=0.0.0.0
PORT=8000

# SQLite database file path.
DB_PATH=./obsidian-sync.db

# Fallback vault path used only if the database has no vault_path set yet.
DEFAULT_VAULT_PATH=./vault

# ---- Security Settings ----

# Comma-separated list of allowed CORS origins (leave blank to disable CORS).
# Only needed if a browser-based client accesses the API from a different origin.
# Example: CORS_ORIGINS=http://localhost:5173,https://my.vault.example.com
CORS_ORIGINS=

# Set to true when running behind a TLS terminator (marks the session cookie Secure).
HTTPS_ONLY=false

# Rate limiting. Set to false to disable in local development.
RATE_LIMIT_ENABLED=true

# Max size (in bytes) for a single file write via REST or WebSocket (default: 10 MB).
MAX_FILE_SIZE_BYTES=10485760
